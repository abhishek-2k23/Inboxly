# ---------------------------------------------------------------------------
# Copy this file to .env and fill in real values.
# .env is gitignored - never commit real secrets.
# ---------------------------------------------------------------------------

# ---- General -----------------------------------------------------------
NODE_ENV=development

# ---- Postgres (used by docker-compose & apps/api) ----------------------
POSTGRES_USER=hackathon
POSTGRES_PASSWORD=hackathon_dev_password
POSTGRES_DB=hackathon
POSTGRES_PORT=5432
# Full connection string used by apps/api (pg)
DATABASE_URL=postgresql://hackathon:hackathon_dev_password@localhost:5432/hackathon

# ---- Redis (used by docker-compose & apps/api) --------------------------
REDIS_PORT=6379
# Full connection string used by apps/api (ioredis)
REDIS_URL=redis://localhost:6379

# ---- apps/api (Express) -------------------------------------------------
API_PORT=4000
# Comma-separated list of allowed CORS origins
CORS_ORIGIN=http://localhost:3000

# ---- AI provider (OpenAI SDK) -------------------------------------------
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_MODEL=gpt-4o-mini

# ---- Auth (Clerk) ---------------------------------------------------------
# Create an app at https://dashboard.clerk.com, enable Google + Email/Password
# under "User & authentication", and copy the keys below.
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME
# Signing secret for the /api/webhooks/clerk endpoint (Webhooks -> Add endpoint)
CLERK_WEBHOOK_SIGNING_SECRET=whsec_REPLACE_ME

# ---- Gmail & Calendar (Corsair) ------------------------------------------
# Base URLs used to build the Google OAuth redirect URI and the post-connect
# redirect back to the frontend (see "Connecting Gmail & Calendar (Corsair)" in README).
API_BASE_URL=http://localhost:4000
WEB_APP_URL=http://localhost:3000
# Key-encryption key for Corsair's stored OAuth credentials. Generate with:
#   openssl rand -base64 32
CORSAIR_KEK=REPLACE_ME
# OAuth 2.0 Client (Web application) from https://console.cloud.google.com,
# with the Gmail API and Google Calendar API enabled. Add
# http://localhost:4000/api/integrations/google/callback as an authorized
# redirect URI. See "Connecting Gmail & Calendar (Corsair)" in README.
GOOGLE_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=REPLACE_ME

# ---- Sentry (error tracking, optional) ------------------------------------
# Create projects at https://sentry.io and paste the DSNs below.
# Leave blank to disable Sentry entirely.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_DSN=

# ---- apps/web (Next.js) --------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000
WEB_PORT=3000

# ---- ngrok (optional tunneling) -----------------------------------------
# Get a token at https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=REPLACE_ME
# Optional: reserved domain, e.g. your-name.ngrok-free.app
NGROK_DOMAIN=
