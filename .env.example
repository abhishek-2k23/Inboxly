# ---------------------------------------------------------------------------
# Copy this file to .env and fill in real values.
# .env is gitignored - never commit real secrets.
# ---------------------------------------------------------------------------

# ---- General -----------------------------------------------------------
NODE_ENV=development

# ---- Postgres (used by docker-compose & apps/api) ----------------------
POSTGRES_USER=hackathon
POSTGRES_PASSWORD=hackathon_dev_password
POSTGRES_DB=hackathon
POSTGRES_PORT=5432
# Full connection string used by apps/api (pg)
DATABASE_URL=postgresql://hackathon:hackathon_dev_password@localhost:5432/hackathon

# ---- Redis (used by docker-compose & apps/api) --------------------------
REDIS_PORT=6379
# Full connection string used by apps/api (ioredis)
REDIS_URL=redis://localhost:6379

# ---- apps/api (Express) -------------------------------------------------
API_PORT=4000
# Comma-separated list of allowed CORS origins
CORS_ORIGIN=http://localhost:3000

# ---- AI provider (OpenAI SDK) -------------------------------------------
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_MODEL=gpt-4o-mini

# ---- apps/web (Next.js) --------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000
WEB_PORT=3000

# ---- ngrok (optional tunneling) -----------------------------------------
# Get a token at https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=REPLACE_ME
# Optional: reserved domain, e.g. your-name.ngrok-free.app
NGROK_DOMAIN=
