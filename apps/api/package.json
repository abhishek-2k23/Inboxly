{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --import ./src/instrument.ts src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --import ./dist/instrument.js dist/index.js",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@clerk/express": "^2.1.25",
    "@corsair-dev/gmail": "^0.1.4",
    "@corsair-dev/googlecalendar": "^0.1.3",
    "@repo/shared": "workspace:*",
    "@sentry/node": "^10.57.0",
    "cors": "^2.8.5",
    "corsair": "^0.1.76",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "ioredis": "^5.11.1",
    "marked": "^18.0.5",
    "openai": "^4.77.0",
    "pg": "^8.13.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.17.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
