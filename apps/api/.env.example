# Copy to .env for local apps/api dev (outside Docker)
API_PORT=4000
CORS_ORIGIN=http://localhost:3000

DATABASE_URL=postgresql://hackathon:hackathon_dev_password@localhost:5432/hackathon

REDIS_URL=redis://localhost:6379

OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_MODEL=gpt-4o-mini

# Create an app at https://dashboard.clerk.com, enable Google + Email/Password
# under "User & authentication", and copy the keys below.
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME
# Signing secret for the /api/webhooks/clerk endpoint (Webhooks -> Add endpoint)
CLERK_WEBHOOK_SIGNING_SECRET=whsec_REPLACE_ME

# Base URLs used to build the Google OAuth redirect URI and the post-connect
# redirect back to the frontend (see "Connecting Gmail & Calendar (Corsair)" in README).
API_BASE_URL=http://localhost:4000
WEB_APP_URL=http://localhost:3000

# ---- Gmail & Calendar (Corsair) ------------------------------------------
# Key-encryption key for Corsair's stored OAuth credentials. Generate with:
#   openssl rand -base64 32
CORSAIR_KEK=REPLACE_ME

# OAuth 2.0 Client (Web application) from https://console.cloud.google.com,
# with the Gmail API and Google Calendar API enabled. Add
# http://localhost:4000/api/integrations/google/callback as an authorized
# redirect URI. See "Connecting Gmail & Calendar (Corsair)" in README.
GOOGLE_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=REPLACE_ME

# ---- Sentry (error tracking, optional) ------------------------------------
# Create a Node project at https://sentry.io and paste its DSN below.
# Leave blank to disable Sentry entirely.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---- Gmail Pub/Sub webhook (real-time inbox sync) -------------------------
# Resource name of a Pub/Sub topic that gmail-api-push@system.gserviceaccount.com
# has been granted Pub/Sub Publisher on, e.g.
#   projects/<gcp-project-id>/topics/<topic-name>
GMAIL_PUBSUB_TOPIC=
# Shared secret appended as ?token=... to the Pub/Sub push subscription URL so
# we can reject requests that don't come from our subscription. Generate with:
#   openssl rand -hex 24
GMAIL_WEBHOOK_TOKEN=
