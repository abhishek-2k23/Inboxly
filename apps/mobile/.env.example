# Clerk publishable key (get from https://dashboard.clerk.com)
# API and web URLs come from app.json `expo.extra` (apiUrl / webUrl), not here.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Google OAuth client IDs (get from https://console.cloud.google.com → APIs & Services → Credentials)
# Web client ID — used for token exchange with Clerk on both platforms
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=XXXXXXXXXX.apps.googleusercontent.com
# Android client ID — register with SHA-1 fingerprint in Google Cloud Console (not used in code)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=XXXXXXXXXX.apps.googleusercontent.com
# iOS client ID — create an "iOS" OAuth credential with bundle ID com.iamabhishek01.inboxly
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=XXXXXXXXXX.apps.googleusercontent.com
